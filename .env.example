# inInfra — example environment for local development (pnpm dev).
# Copy to .env and adjust. See docs/CONFIGURATION.md for the full reference.
# The API loads .env automatically; do not commit your real .env.

# ─────────────────────────────────────────────────────────────────────────────
# API (Rust/axum) — apps/api
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (required). Migrations run automatically at startup.
DATABASE_URL=postgres://ininfra:ininfra@localhost:5432/ininfra

# Session JWT signing key (required, >=32 random bytes). Generate with:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-at-least-32-random-bytes-0000000000

# Bootstrap admin (upserted at startup; both must be set together).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Comma-separated namespaces the console may read/operate on (default: default).
MANAGED_NAMESPACES=default

# UI display (optional).
CLUSTER_NAME=local
PRODUCT_NAME=inInfra

# Build catalog ConfigMap name (optional; default: ininfra-build-catalog).
BUILD_CATALOG_CONFIGMAP=ininfra-build-catalog

# Namespace where CI/CD lives (optional; default: first managed namespace).
# CICD_NAMESPACE=default

# Jenkins integration (optional; enables the builds/deploys features).
# JENKINS_BASE_URL=http://localhost:8081
# JENKINS_USER=your-jenkins-user
# JENKINS_API_TOKEN=your-jenkins-token

# AWS / ECR (optional; enables image inventory, delete, and commit resolution).
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=your-region

# Spot/preemptible node detection (all optional; empty = disabled). Standard
# cloud labels (EKS, Karpenter) are always detected; set these to also recognize
# your own spot label/taint.
# SPOT_LABEL_KEY=node.kubernetes.io/lifecycle   # node label key marking spot nodes
# SPOT_LABEL_VALUE=spot                          # required label value (empty = any value)
# SPOT_TAINT_KEY=spot                            # node taint key marking spot nodes

# API listen address (optional; default: 0.0.0.0:8080).
BIND_ADDR=0.0.0.0:8080

# ─────────────────────────────────────────────────────────────────────────────
# Web (Next.js) — apps/web
# ─────────────────────────────────────────────────────────────────────────────

# In-cluster / local URL of the API. The Next rewrite proxies /api/* here.
# In dev this defaults to http://localhost:8080 if unset.
API_INTERNAL_URL=http://localhost:8080

# Web listen port (optional; default: 3000).
PORT=3000
